def get_char(tile):
    """整数/字符串 tile ID → 显示字符。"""
    from tile_props import get_tile_char
    return get_tile_char(tile)


def get_color_attr(tile):
    """tile → (color_name, attr_name)，按 name 字段查，
    避免共用符号的材质被强制同色。"""
    from tile_props import get_tile_props
    name = get_tile_props(tile).get("name", "")
    entry = CODEX.get(name, {"color": "white", "attr": "normal"})
    return entry["color"], entry["attr"]
